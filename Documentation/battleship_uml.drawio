        <mxCell id="rsXUU119HayOltydHdFh-18" value="Ship sections are parts of ships&lt;div&gt;&amp;nbsp;(similar to nodes in a linked list)&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="625" y="380" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-19" value="Ship is the culmination&lt;div&gt;&amp;nbsp;of ship sections&amp;nbsp;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="445" y="495" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-20" value="Board is a 10x10 grid that can hold&lt;div&gt;&amp;nbsp;and place ships on itself.&lt;/div&gt;&lt;div&gt;Also converts user input (A6 -&amp;gt; 0,5)&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="215" y="485" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-21" value="Player uses boards and ships&lt;div&gt;&amp;nbsp;to determine shots and update&lt;/div&gt;&lt;div&gt;their respective boards&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="505" y="290" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-22" value="Bot is very similar to player,&amp;nbsp;&lt;div&gt;but has&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;built in functions&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;to manage how it searches&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="20" y="180" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-23" value="Game Engine initializes both the player&amp;nbsp;&lt;div&gt;and bot objects&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;and implements bot functions&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;to help it search for player ships (search/hunt)&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="510" y="165" width="270" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-25" value="Console version: Works &lt;i&gt;beautifully&lt;/i&gt;&lt;div&gt;Initializes everything and runs engine&amp;nbsp;&lt;/div&gt;&lt;div&gt;functions until there&#39;s a winner&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="140" y="30" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rsXUU119HayOltydHdFh-26" value="GUI version: Works....kind of?&lt;div&gt;Same concept as driver.py, but not as&amp;nbsp;&lt;/div&gt;&lt;div&gt;pretty&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;and still has bugs (somehow)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Plus side? Music!&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="464" y="25" width="230" height="70" as="geometry" />
        </mxCell>
